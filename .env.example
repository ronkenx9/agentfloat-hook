# ─── TESTNET (current default) ────────────────────────────────────────
X_LAYER_RPC_URL=https://testrpc.xlayer.tech/terigon
X_LAYER_CHAIN_ID=1952

# ─── MAINNET (for production deployment) ──────────────────────────────
# Switch by setting these and reusing X_LAYER_RPC_URL/CHAIN_ID variables
# X_LAYER_RPC_URL=https://rpc.xlayer.tech
# X_LAYER_CHAIN_ID=196
# Canonical mainnet infra (no need to redeploy):
#   PoolManager  = 0x360E68faCCca8cA495c1B759Fd9EEe466dB9FB32
#   Aave Pool    = 0xE3F3Caefdd7180F884c01E57f65Df979Af84f116
#   USDT         = 0x779Ded0c9e1022225f8E0630b35a9b54bE713736
#   aUSDT        = 0xF356ae412dB5df43BD3a10746f7ad4e1C4De4297
# After mainnet deploy, fill in:
# VAULT_ADDRESS=
# HOOK_ADDRESS=
# HOOK_SALT=

# Address that will be set as the promoter on FloatVault (optional, defaults to DEPLOYER)
PROMOTER_ADDRESS=
DEPLOYER_ADDRESS=
DEPLOYER_PRIVATE_KEY=
PROMOTER_PRIVATE_KEY=
USDC_ADDRESS=
POOL_MANAGER_ADDRESS=
VAULT_ADDRESS=
HOOK_ADDRESS=

# Strategy Orchestrator (LLM brain) — uses Groq for hourly proposals
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Dashboard API — agent serves the REST API the dashboard reads from
AGENTFLOAT_API_PORT=4000
DASHBOARD_ORIGIN=http://localhost:3000

# SQLite DB path — defaults to ~/brain/.agentfloat.db
AGENTFLOAT_DB=

# Admin wallet whitelist (comma-separated lowercase 0x addresses).
# Only these wallets can change operating mode or reject proposals via SIWE.
# Empty in dev = accept any signed wallet.
ADMIN_WALLETS=
